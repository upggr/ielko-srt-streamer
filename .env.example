# -------------------------------------------------------
# REQUIRED — only this needs to be set before first boot
# -------------------------------------------------------
LICENSE_KEY=your-license-key-from-services.buy-it.gr

# -------------------------------------------------------
# OPTIONAL — auto-generated or auto-detected on first boot
# -------------------------------------------------------
# APP_PASSWORD     → random 32-char secret stored in DB volume
# SESSION_SECRET   → random 40-char secret stored in DB volume
# SERVER_IP        → auto-detected via ifconfig.me on first boot
# PUBLIC_URL       → derived as http://<SERVER_IP>:3000 on first boot
#                    (update via UI Settings once domain/SSL is configured)

# Uncomment to override auto-detection:
# APP_PASSWORD=change_me
# SESSION_SECRET=change_me
# SERVER_IP=1.2.3.4
# PUBLIC_URL=https://streams.example.com

# License validation endpoint (default: services.buy-it.gr)
# LICENSE_VALIDATE_URL=https://services.buy-it.gr/api/license/validate
